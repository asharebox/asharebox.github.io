{"content":"{\"__ud_title\":\"OpenClaw权限太大\",\"__ud_tags\":[\"Tools\",\"openclaw\",\"nanobot\"],\"__ud_update_time\":1773886719511,\"__ud_create_time\":1773886717344,\"__ud_draft\":false,\"type\":\"doc\",\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":1,\"id\":\"OpenClaw权限太大\"},\"content\":[{\"type\":\"text\",\"text\":\"OpenClaw权限太大\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"现状：\"}]},{\"type\":\"bulletList\",\"content\":[{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"🔴 \"},{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"权限太大\"},{\"type\":\"text\",\"text\":\"：AdministratorAccess 能干任何事，风险太高\"}]}]},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"🔴 \"},{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"网络暴露\"},{\"type\":\"text\",\"text\":\"：直接部署在公网，安全风险大\"}]}]},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"🔴 \"},{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"密钥硬编码\"},{\"type\":\"text\",\"text\":\"：API Key 写在配置文件里，容易泄露\"}]}]},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"🔴 \"},{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"没有审计\"},{\"type\":\"text\",\"text\":\"：不知道 OpenClaw 调用了哪些 API\"}]}]},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"🔴 \"},{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"缺乏监控\"},{\"type\":\"text\",\"text\":\"：出了安全问题也不知道\"}]}]}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"改造后的架构长这样：\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"  \"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":\"java\"},\"content\":[{\"type\":\"text\",\"text\":\"🌐 Internet\\n     ↓\\n🚪 NAT Gateway → 🏠 Private Subnet (OpenClaw)\\n     ↓                    ↓\\n🛡️ Security Group ←→ 📊 CloudWatch Logs\\n   (仅开必要端口)         📋 CloudTrail\\n                        🔐 Secrets Manager\\n                        👤 IAM Role (最小权限)\\n\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":2,\"id\":\"-第一招权限收紧大法\"},\"content\":[{\"type\":\"text\",\"text\":\"💪 第一招：权限收紧大法\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"创建专属-IAM-策略\"},\"content\":[{\"type\":\"text\",\"text\":\"创建专属 IAM 策略\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"以前直接用 AdministratorAccess，现在我们精确控制权限：\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"  \"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":\"python\"},\"content\":[{\"type\":\"text\",\"text\":\"import boto3\\nimport json\\n\\ndef create_minimal_policy():\\n    \\\"\\\"\\\"创建 OpenClaw 最小权限策略\\\"\\\"\\\"\\n    iam = boto3.client('iam')\\n    \\n    # 这就是 OpenClaw 真正需要的权限，多一个都不给\\n    policy_doc = {\\n        \\\"Version\\\": \\\"2012-10-17\\\",\\n        \\\"Statement\\\": [\\n            # Bedrock 调用权限（核心功能）\\n            {\\n                \\\"Effect\\\": \\\"Allow\\\",\\n                \\\"Action\\\": [\\n                    \\\"bedrock:InvokeModel\\\",\\n                    \\\"bedrock:InvokeModelWithResponseStream\\\"\\n                ],\\n                \\\"Resource\\\": [\\n                    \\\"arn:aws:bedrock:*:*:model/anthropic.claude*\\\",\\n                    \\\"arn:aws:bedrock:*:*:model/amazon.titan*\\\"\\n                ]\\n            },\\n            # S3 读写权限（存储数据）\\n            {\\n                \\\"Effect\\\": \\\"Allow\\\",\\n                \\\"Action\\\": [\\n                    \\\"s3:GetObject\\\",\\n                    \\\"s3:PutObject\\\", \\n                    \\\"s3:DeleteObject\\\",\\n                    \\\"s3:ListBucket\\\"\\n                ],\\n                \\\"Resource\\\": [\\n                    \\\"arn:aws:s3:::openclaw-data-*/*\\\",\\n                    \\\"arn:aws:s3:::openclaw-data-*\\\"\\n                ]\\n            },\\n            # 密钥读取权限\\n            {\\n                \\\"Effect\\\": \\\"Allow\\\",\\n                \\\"Action\\\": \\\"secretsmanager:GetSecretValue\\\",\\n                \\\"Resource\\\": \\\"arn:aws:secretsmanager:*:*:secret:openclaw/*\\\"\\n            },\\n            # 日志写入权限\\n            {\\n                \\\"Effect\\\": \\\"Allow\\\",\\n                \\\"Action\\\": [\\n                    \\\"logs:CreateLogGroup\\\",\\n                    \\\"logs:CreateLogStream\\\",\\n                    \\\"logs:PutLogEvents\\\"\\n                ],\\n                \\\"Resource\\\": \\\"arn:aws:logs:*:*:log-group:/openclaw/*\\\"\\n            }\\n        ]\\n    }\\n    \\n    # 创建策略\\n    response = iam.create_policy(\\n        PolicyName='OpenClawMinimalPolicy',\\n        PolicyDocument=json.dumps(policy_doc),\\n        Description='OpenClaw 最小权限策略，够用就行'\\n    )\\n    \\n    print(f\\\"🎉 策略创建成功: {response['Policy']['Arn']}\\\")\\n    return response['Policy']['Arn']\\n\\n# 创建对应的 IAM 角色\\ndef create_role(policy_arn):\\n    \\\"\\\"\\\"创建 IAM 角色并绑定策略\\\"\\\"\\\"\\n    iam = boto3.client('iam')\\n    \\n    # EC2 可以使用这个角色\\n    trust_policy = {\\n        \\\"Version\\\": \\\"2012-10-17\\\",\\n        \\\"Statement\\\": [{\\n            \\\"Effect\\\": \\\"Allow\\\",\\n            \\\"Principal\\\": {\\\"Service\\\": \\\"ec2.amazonaws.com\\\"},\\n            \\\"Action\\\": \\\"sts:AssumeRole\\\"\\n        }]\\n    }\\n    \\n    # 创建角色\\n    iam.create_role(\\n        RoleName='OpenClawRole',\\n        AssumeRolePolicyDocument=json.dumps(trust_policy)\\n    )\\n    \\n    # 绑定我们的最小权限策略\\n    iam.attach_role_policy(\\n        RoleName='OpenClawRole',\\n        PolicyArn=policy_arn\\n    )\\n    \\n    # 创建实例配置文件（EC2 需要这个）\\n    iam.create_instance_profile(InstanceProfileName='OpenClawProfile')\\n    iam.add_role_to_instance_profile(\\n        InstanceProfileName='OpenClawProfile',\\n        RoleName='OpenClawRole'\\n    )\\n    \\n    print(\\\"✅ IAM 角色设置完毕\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    policy_arn = create_minimal_policy()\\n    create_role(policy_arn)\\n\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"权限测试脚本\"},\"content\":[{\"type\":\"text\",\"text\":\"权限测试脚本\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"写代码一定要测试，权限配置也一样：\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"  \"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":\"python\"},\"content\":[{\"type\":\"text\",\"text\":\"def test_permissions():\\n    \\\"\\\"\\\"测试权限是否配置正确\\\"\\\"\\\"\\n    \\n    tests = [\\n        # 测试 Bedrock\\n        {\\n            'name': 'Bedrock 权限',\\n            'test': lambda: boto3.client('bedrock-runtime'),\\n            'should_work': True\\n        },\\n        # 测试 S3\\n        {\\n            'name': 'S3 权限',\\n            'test': lambda: boto3.client('s3').head_bucket(Bucket='openclaw-data-test'),\\n            'should_work': True\\n        },\\n        # 测试不应该有的权限（比如 EC2）\\n        {\\n            'name': 'EC2 权限（应该没有）',\\n            'test': lambda: boto3.client('ec2').describe_instances(),\\n            'should_work': False\\n        }\\n    ]\\n    \\n    for test in tests:\\n        try:\\n            test['test']()\\n            result = \\\"✅ 正常\\\" if test['should_work'] else \\\"❌ 权限过大\\\"\\n        except Exception as e:\\n            result = \\\"❌ 异常\\\" if test['should_work'] else \\\"✅ 正确拒绝\\\"\\n        \\n        print(f\\\"{test['name']}: {result}\\\")\\n\\ntest_permissions()\\n\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":2,\"id\":\"-第二招私有网络部署\"},\"content\":[{\"type\":\"text\",\"text\":\"🏠 第二招：私有网络部署\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"搭建安全的-VPC\"},\"content\":[{\"type\":\"text\",\"text\":\"搭建安全的 VPC\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"把 OpenClaw 藏到私有子网里，这样就算有漏洞，外网也访问不到：\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"  \"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":\"python\"},\"content\":[{\"type\":\"text\",\"text\":\"def setup_secure_vpc():\\n    \\\"\\\"\\\"搭建安全的 VPC 网络\\\"\\\"\\\"\\n    ec2 = boto3.client('ec2')\\n    \\n    print(\\\"🏗️ 开始搭建 VPC...\\\")\\n    \\n    # 1. 创建 VPC\\n    vpc = ec2.create_vpc(CidrBlock='10.0.0.0/16')\\n    vpc_id = vpc['Vpc']['VpcId']\\n    print(f\\\"✅ VPC 创建完成: {vpc_id}\\\")\\n    \\n    # 2. 创建子网\\n    # 私有子网（OpenClaw 住这里）\\n    private_subnet = ec2.create_subnet(\\n        VpcId=vpc_id,\\n        CidrBlock='10.0.1.0/24',\\n        AvailabilityZone='us-east-1a'\\n    )\\n    \\n    # 公网子网（NAT Gateway 住这里）\\n    public_subnet = ec2.create_subnet(\\n        VpcId=vpc_id,\\n        CidrBlock='10.0.2.0/24',\\n        AvailabilityZone='us-east-1a'\\n    )\\n    \\n    # 3. 设置 Internet Gateway（公网访问必须）\\n    igw = ec2.create_internet_gateway()\\n    igw_id = igw['InternetGateway']['InternetGatewayId']\\n    ec2.attach_internet_gateway(InternetGatewayId=igw_id, VpcId=vpc_id)\\n    \\n    # 4. 创建 NAT Gateway（私有子网上网必须）\\n    # 先分配一个公网 IP\\n    eip = ec2.allocate_address(Domain='vpc')\\n    \\n    # 然后创建 NAT Gateway\\n    nat_gw = ec2.create_nat_gateway(\\n        SubnetId=public_subnet['Subnet']['SubnetId'],\\n        AllocationId=eip['AllocationId']\\n    )\\n    nat_gw_id = nat_gw['NatGateway']['NatGatewayId']\\n    \\n    print(\\\"🚪 NAT Gateway 创建完成，私有子网可以上网了\\\")\\n    \\n    return {\\n        'vpc_id': vpc_id,\\n        'private_subnet_id': private_subnet['Subnet']['SubnetId'],\\n        'public_subnet_id': public_subnet['Subnet']['SubnetId'],\\n        'nat_gw_id': nat_gw_id,\\n        'igw_id': igw_id\\n    }\\n\\n# 配置路由（很重要，不然网络不通）\\ndef setup_routes(infra):\\n    \\\"\\\"\\\"配置网络路由\\\"\\\"\\\"\\n    ec2 = boto3.client('ec2')\\n    \\n    # 给私有子网创建路由表\\n    private_rt = ec2.create_route_table(VpcId=infra['vpc_id'])\\n    private_rt_id = private_rt['RouteTable']['RouteTableId']\\n    \\n    # 私有子网的流量都走 NAT Gateway\\n    ec2.create_route(\\n        RouteTableId=private_rt_id,\\n        DestinationCidrBlock='0.0.0.0/0',\\n        NatGatewayId=infra['nat_gw_id']\\n    )\\n    \\n    # 把私有子网关联到这个路由表\\n    ec2.associate_route_table(\\n        RouteTableId=private_rt_id,\\n        SubnetId=infra['private_subnet_id']\\n    )\\n    \\n    print(\\\"🛣️ 网络路由配置完成\\\")\\n\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"Security-Group-配置\"},\"content\":[{\"type\":\"text\",\"text\":\"Security Group 配置\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"安全组就是防火墙，只开必要的端口：\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"  \"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":\"python\"},\"content\":[{\"type\":\"text\",\"text\":\"def create_security_group(vpc_id):\\n    \\\"\\\"\\\"创建 OpenClaw 专用安全组\\\"\\\"\\\"\\n    ec2 = boto3.client('ec2')\\n    \\n    # 创建安全组\\n    sg = ec2.create_security_group(\\n        GroupName='OpenClawSecure',\\n        Description='OpenClaw 安全组 - 只开必要端口',\\n        VpcId=vpc_id\\n    )\\n    sg_id = sg['GroupId']\\n    \\n    # 入站规则：只允许必要的访问\\n    ec2.authorize_security_group_ingress(\\n        GroupId=sg_id,\\n        IpPermissions=[\\n            # SSH 访问（只允许 VPC 内部）\\n            {\\n                'IpProtocol': 'tcp',\\n                'FromPort': 22,\\n                'ToPort': 22,\\n                'IpRanges': [{'CidrIp': '10.0.0.0/16'}]\\n            },\\n            # OpenClaw 端口（只允许 VPC 内部）\\n            {\\n                'IpProtocol': 'tcp',\\n                'FromPort': 8080,\\n                'ToPort': 8080,\\n                'IpRanges': [{'CidrIp': '10.0.0.0/16'}]\\n            }\\n        ]\\n    )\\n    \\n    print(f\\\"🛡️ 安全组创建完成: {sg_id}\\\")\\n    return sg_id\\n\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":2,\"id\":\"-第三招密钥管理升级\"},\"content\":[{\"type\":\"text\",\"text\":\"🔐 第三招：密钥管理升级\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"用-Secrets-Manager-管理密钥\"},\"content\":[{\"type\":\"text\",\"text\":\"用 Secrets Manager 管理密钥\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"以前 API Key 直接写在配置文件里，现在用亚马逊云科技的密钥管理服务：\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"  \"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":\"python\"},\"content\":[{\"type\":\"text\",\"text\":\"def setup_secret_management():\\n    \\\"\\\"\\\"设置密钥管理\\\"\\\"\\\"\\n    secrets = boto3.client('secretsmanager')\\n    \\n    # 创建密钥\\n    secret_data = {\\n        \\\"bedrock_api_key\\\": \\\"your-actual-bedrock-key\\\",\\n        \\\"openai_api_key\\\": \\\"backup-openai-key\\\",  # 备用密钥\\n        \\\"database_password\\\": \\\"super-secure-password\\\"\\n    }\\n    \\n    secrets.create_secret(\\n        Name='openclaw/prod/api-keys',\\n        Description='OpenClaw 生产环境 API 密钥',\\n        SecretString=json.dumps(secret_data)\\n    )\\n    \\n    print(\\\"🔑 密钥管理设置完成\\\")\\n\\n# OpenClaw 代码中这样读取密钥\\ndef get_api_key(key_name):\\n    \\\"\\\"\\\"安全地获取 API 密钥\\\"\\\"\\\"\\n    secrets = boto3.client('secretsmanager')\\n    \\n    try:\\n        response = secrets.get_secret_value(\\n            SecretId='openclaw/prod/api-keys'\\n        )\\n        all_secrets = json.loads(response['SecretString'])\\n        return all_secrets.get(key_name)\\n    except Exception as e:\\n        print(f\\\"❌ 获取密钥失败: {e}\\\")\\n        return None\\n\\n# 使用示例\\nbedrock_key = get_api_key('bedrock_api_key')\\nif bedrock_key:\\n    print(\\\"✅ 密钥获取成功\\\")\\nelse:\\n    print(\\\"❌ 密钥获取失败\\\")\\n\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":2,\"id\":\"-第四招审计日志全覆盖\"},\"content\":[{\"type\":\"text\",\"text\":\"📊 第四招：审计日志全覆盖\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"设置-CloudTrail-和-CloudWatch\"},\"content\":[{\"type\":\"text\",\"text\":\"设置 CloudTrail 和 CloudWatch\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"出了问题要能查到是谁干的，这就需要日志记录：\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"  \"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":\"python\"},\"content\":[{\"type\":\"text\",\"text\":\"def setup_audit_logging():\\n    \\\"\\\"\\\"设置审计日志\\\"\\\"\\\"\\n    cloudtrail = boto3.client('cloudtrail')\\n    logs = boto3.client('logs')\\n    s3 = boto3.client('s3')\\n    \\n    # 1. 创建 S3 桶存储 CloudTrail 日志\\n    bucket_name = f'openclaw-audit-logs-{int(time.time())}'  # 唯一桶名\\n    s3.create_bucket(Bucket=bucket_name)\\n    \\n    # 设置桶策略（让 CloudTrail 能写入）\\n    bucket_policy = {\\n        \\\"Version\\\": \\\"2012-10-17\\\",\\n        \\\"Statement\\\": [{\\n            \\\"Effect\\\": \\\"Allow\\\",\\n            \\\"Principal\\\": {\\\"Service\\\": \\\"cloudtrail.amazonaws.com\\\"},\\n            \\\"Action\\\": \\\"s3:PutObject\\\",\\n            \\\"Resource\\\": f\\\"arn:aws:s3:::{bucket_name}/*\\\"\\n        }]\\n    }\\n    \\n    s3.put_bucket_policy(\\n        Bucket=bucket_name,\\n        Policy=json.dumps(bucket_policy)\\n    )\\n    \\n    # 2. 创建 CloudTrail\\n    cloudtrail.create_trail(\\n        Name='OpenClawAuditTrail',\\n        S3BucketName=bucket_name,\\n        IncludeGlobalServiceEvents=True,\\n        IsMultiRegionTrail=True\\n    )\\n    \\n    # 启动日志记录\\n    cloudtrail.start_logging(Name='OpenClawAuditTrail')\\n    \\n    # 3. 创建 CloudWatch 日志组（应用日志）\\n    logs.create_log_group(\\n        logGroupName='/openclaw/app-logs',\\n        tags={'Environment': 'prod', 'Component': 'openclaw'}\\n    )\\n    \\n    print(\\\"📋 审计日志设置完成\\\")\\n    print(f\\\"   - API 调用日志: S3 桶 {bucket_name}\\\")\\n    print(\\\"   - 应用日志: CloudWatch Logs /openclaw/app-logs\\\")\\n\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":2,\"id\":\"-第五招自动安全检查\"},\"content\":[{\"type\":\"text\",\"text\":\"🤖 第五招：自动安全检查\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"Lambda-安全扫描器\"},\"content\":[{\"type\":\"text\",\"text\":\"Lambda 安全扫描器\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"写个 Lambda 函数定期检查安全配置，有问题自动告警：\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"  \"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":\"python\"},\"content\":[{\"type\":\"text\",\"text\":\"def security_scanner_lambda():\\n    \\\"\\\"\\\"Lambda 安全扫描器代码\\\"\\\"\\\"\\n    lambda_code = '''\\nimport boto3\\nimport json\\n\\ndef lambda_handler(event, context):\\n    \\\"\\\"\\\"定期安全检查\\\"\\\"\\\"\\n    ec2 = boto3.client('ec2')\\n    sns = boto3.client('sns')\\n    \\n    risks = []\\n    \\n    # 检查所有安全组\\n    for sg in ec2.describe_security_groups()['SecurityGroups']:\\n        # 跳过默认安全组\\n        if sg['GroupName'] == 'default':\\n            continue\\n            \\n        # 检查是否有危险的开放端口\\n        for rule in sg['IpPermissions']:\\n            for ip_range in rule.get('IpRanges', []):\\n                if ip_range.get('CidrIp') == '0.0.0.0/0':\\n                    # 只允许 HTTP/HTTPS 对外开放\\n                    port = rule.get('FromPort', 0)\\n                    if port not in [80, 443]:\\n                        risks.append({\\n                            'type': '危险端口开放',\\n                            'resource': sg['GroupId'],\\n                            'detail': f'端口 {port} 对全网开放',\\n                            'severity': 'HIGH'\\n                        })\\n    \\n    # 如果有风险，发送告警\\n    if risks:\\n        message = {\\n            'timestamp': context.aws_request_id,\\n            'risks_found': len(risks),\\n            'details': risks\\n        }\\n        \\n        sns.publish(\\n            TopicArn='arn:aws:sns:us-east-1:123456789:openclaw-alerts',\\n            Message=json.dumps(message, indent=2),\\n            Subject=f'🚨 OpenClaw 安全风险告警 ({len(risks)} 个问题)'\\n        )\\n    \\n    return {\\n        'statusCode': 200,\\n        'body': json.dumps({\\n            'risks_found': len(risks),\\n            'message': '安全检查完成' if not risks else '发现安全风险'\\n        })\\n    }\\n    '''\\n    \\n    return lambda_code\\n\\n# 部署 Lambda 函数\\ndef deploy_security_scanner():\\n    \\\"\\\"\\\"部署安全扫描器\\\"\\\"\\\"\\n    lambda_client = boto3.client('lambda')\\n    \\n    # 创建 ZIP 包\\n    import zipfile\\n    import tempfile\\n    \\n    with tempfile.NamedTemporaryFile(suffix='.zip', delete=False) as tmp:\\n        with zipfile.ZipFile(tmp.name, 'w') as z:\\n            z.writestr('lambda_function.py', security_scanner_lambda())\\n        \\n        # 部署函数\\n        with open(tmp.name, 'rb') as zip_file:\\n            lambda_client.create_function(\\n                FunctionName='OpenClawSecurityScanner',\\n                Runtime='python3.9',\\n                Role='arn:aws:iam::YOUR-ACCOUNT:role/OpenClawScannerRole',\\n                Handler='lambda_function.lambda_handler',\\n                Code={'ZipFile': zip_file.read()},\\n                Timeout=60\\n            )\\n    \\n    print(\\\"🤖 安全扫描器部署完成\\\")\\n\\n# 设置定时任务（每天检查一次）\\ndef setup_scheduler():\\n    \\\"\\\"\\\"设置定时扫描\\\"\\\"\\\"\\n    events = boto3.client('events')\\n    \\n    # 创建定时规则（每天上午 9 点）\\n    events.put_rule(\\n        Name='OpenClawSecurityCheck',\\n        Description='每日安全检查',\\n        ScheduleExpression='cron(0 9 * * ? *)'  # 上午 9 点\\n    )\\n    \\n    # 关联到 Lambda 函数\\n    events.put_targets(\\n        Rule='OpenClawSecurityCheck',\\n        Targets=[{\\n            'Id': '1',\\n            'Arn': 'arn:aws:lambda:us-east-1:YOUR-ACCOUNT:function:OpenClawSecurityScanner'\\n        }]\\n    )\\n    \\n    print(\\\"⏰ 定时安全检查设置完成\\\")\\n\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":2,\"id\":\"-一键部署脚本\"},\"content\":[{\"type\":\"text\",\"text\":\"🚀 一键部署脚本\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"把所有步骤串起来，写个一键部署脚本：\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"  \"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":\"bash\"},\"content\":[{\"type\":\"text\",\"text\":\"#!/bin/bash\\n# 🚀 OpenClaw 安全部署一键脚本\\n\\nset -e  # 出错就停止\\n\\necho \\\"🦞 开始部署 OpenClaw 安全架构...\\\"\\n\\n# Step 1: IAM 权限\\necho \\\"👤 创建 IAM 策略和角色...\\\"\\npython3 setup_iam.py\\n\\n# Step 2: VPC 网络\\necho \\\"🏠 搭建 VPC 网络...\\\"  \\npython3 setup_vpc.py\\n\\n# Step 3: 密钥管理\\necho \\\"🔐 设置密钥管理...\\\"\\npython3 setup_secrets.py\\n\\n# Step 4: 审计日志\\necho \\\"📊 配置审计日志...\\\"\\npython3 setup_logging.py  \\n\\n# Step 5: 安全扫描\\necho \\\"🤖 部署安全扫描器...\\\"\\npython3 deploy_scanner.py\\n\\n# Step 6: 启动 OpenClaw\\necho \\\"🦞 启动 OpenClaw 实例...\\\"\\naws ec2 run-instances \\\\\\n    --image-id ami-0abcdef1234567890 \\\\\\n    --instance-type t3.medium \\\\\\n    --key-name your-key \\\\\\n    --security-group-ids $SECURITY_GROUP_ID \\\\\\n    --subnet-id $PRIVATE_SUBNET_ID \\\\\\n    --iam-instance-profile Name=OpenClawProfile \\\\\\n    --user-data file://install-openclaw.sh\\n\\necho \\\"✅ 部署完成！\\\"\\necho \\\"\\\"\\necho \\\"📋 接下来要做的事：\\\"\\necho \\\"  1. 等待 EC2 实例启动完成\\\"\\necho \\\"  2. 通过跳板机 SSH 到 OpenClaw 服务器\\\"  \\necho \\\"  3. 检查 OpenClaw 服务状态\\\"\\necho \\\"  4. 验证权限配置正确\\\"\\necho \\\"  5. 测试安全扫描器功能\\\"\\necho \\\"\\\"\\necho \\\"🎉 现在你的 OpenClaw 既安全又好用！\\\"\\n\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":2,\"id\":\"-验证和测试\"},\"content\":[{\"type\":\"text\",\"text\":\"🎯 验证和测试\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"部署完了不测试等于白干，来验证一下效果：\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"安全检查清单\"},\"content\":[{\"type\":\"text\",\"text\":\"安全检查清单\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"  \"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":\"python\"},\"content\":[{\"type\":\"text\",\"text\":\"def security_checklist():\\n    \\\"\\\"\\\"安全检查清单\\\"\\\"\\\"\\n    checks = [\\n        \\\"✅ IAM 权限：只有 Bedrock + S3 + Secrets + Logs\\\",\\n        \\\"✅ 网络隔离：OpenClaw 在私有子网\\\", \\n        \\\"✅ 端口限制：Security Group 只开 22 和 8080\\\",\\n        \\\"✅ 密钥管理：API Key 存在 Secrets Manager\\\",\\n        \\\"✅ 审计日志：CloudTrail + CloudWatch 正常记录\\\", \\n        \\\"✅ 自动检查：Lambda 扫描器每日运行\\\",\\n        \\\"✅ 监控告警：有风险自动通知\\\"\\n    ]\\n    \\n    print(\\\"🔍 安全配置检查清单：\\\")\\n    for check in checks:\\n        print(f\\\"  {check}\\\")\\n\\nsecurity_checklist()\\n\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"成本预估\"},\"content\":[{\"type\":\"text\",\"text\":\"成本预估\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"别忘了算成本，老板最关心这个：\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"  \"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":\"markdown\"},\"content\":[{\"type\":\"text\",\"text\":\"💰 每月成本预估：\\n- EC2 t3.medium (私有子网): ~$30\\n- NAT Gateway: ~$32  \\n- CloudTrail: ~$2\\n- CloudWatch Logs: ~$5\\n- Secrets Manager: ~$0.4\\n- Lambda (安全扫描): ~$0.1\\n--------------------------\\n总计: ~$70/月\\n\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":2,\"id\":\"-总结\"},\"content\":[{\"type\":\"text\",\"text\":\"🎉 总结\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"这套安全方案下来，OpenClaw 的安全等级提升了不止一个档次：\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"-解决的问题\"},\"content\":[{\"type\":\"text\",\"text\":\"✅ 解决的问题\"}]},{\"type\":\"bulletList\",\"content\":[{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"权限过大\"},{\"type\":\"text\",\"text\":\" → IAM 最小权限策略\"}]}]},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"网络暴露\"},{\"type\":\"text\",\"text\":\" → VPC 私有子网部署\"}]}]},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"密钥泄露\"},{\"type\":\"text\",\"text\":\" → Secrets Manager 统一管理\"}]}]},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"缺乏审计\"},{\"type\":\"text\",\"text\":\" → CloudTrail + CloudWatch 全记录\"}]}]},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"被动响应\"},{\"type\":\"text\",\"text\":\" → Lambda 主动扫描 + 自动告警\"}]}]}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"-实际效果\"}}]}","title":"OpenClaw权限太大","tags":["Tools","openclaw","nanobot"],"updateTime":1773886719511,"createTime":1773886717344,"draft":false,"intro":"现状：","html":"<h1 level=\"1\" id=\"OpenClaw权限太大\">OpenClaw权限太大</h1><p>现状：</p><ul><li><p>🔴 <strong>权限太大</strong>：AdministratorAccess 能干任何事，风险太高</p></li><li><p>🔴 <strong>网络暴露</strong>：直接部署在公网，安全风险大</p></li><li><p>🔴 <strong>密钥硬编码</strong>：API Key 写在配置文件里，容易泄露</p></li><li><p>🔴 <strong>没有审计</strong>：不知道 OpenClaw 调用了哪些 API</p></li><li><p>🔴 <strong>缺乏监控</strong>：出了安全问题也不知道</p></li></ul><p>改造后的架构长这样：</p><div class=\"llt-code readonly\"><div class=\"language\">auto</div><div class=\"wrapper\"><pre><code></code></pre></div></div><div class=\"llt-code readonly\"><div class=\"language\">java</div><div class=\"wrapper\"><pre><code class=\"language-java\">🌐 Internet\n     ↓\n🚪 NAT Gateway → 🏠 Private <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">Subnet</span> <span class=\"hljs-params\" class=\"hljs-params\">(OpenClaw)</span>\n     ↓                    ↓\n🛡️ Security Group ←→ 📊 CloudWatch <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">Logs</span>\n   <span class=\"hljs-params\" class=\"hljs-params\">(仅开必要端口)</span>         📋 CloudTrail\n                        🔐 Secrets Manager\n                        👤 IAM <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">Role</span> <span class=\"hljs-params\" class=\"hljs-params\">(最小权限)</span>\n</code></pre></div></div><h2 level=\"2\" id=\"-第一招权限收紧大法\">💪 第一招：权限收紧大法</h2><h3 level=\"3\" id=\"创建专属-IAM-策略\">创建专属 IAM 策略</h3><p>以前直接用 AdministratorAccess，现在我们精确控制权限：</p><div class=\"llt-code readonly\"><div class=\"language\">auto</div><div class=\"wrapper\"><pre><code></code></pre></div></div><div class=\"llt-code readonly\"><div class=\"language\">python</div><div class=\"wrapper\"><pre><code class=\"language-python\"><span class=\"hljs-keyword\" class=\"hljs-keyword\">import</span> boto3\n<span class=\"hljs-keyword\" class=\"hljs-keyword\">import</span> json\n\n<span class=\"hljs-keyword\" class=\"hljs-keyword\">def</span> <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">create_minimal_policy</span>():\n    <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;&quot;创建 OpenClaw 最小权限策略&quot;&quot;&quot;</span>\n    iam = boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;iam&apos;</span>)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 这就是 OpenClaw 真正需要的权限，多一个都不给</span>\n    policy_doc = {\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;Version&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;2012-10-17&quot;</span>,\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;Statement&quot;</span>: [\n            <span class=\"hljs-comment\" class=\"hljs-comment\"># Bedrock 调用权限（核心功能）</span>\n            {\n                <span class=\"hljs-string\" class=\"hljs-string\">&quot;Effect&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;Allow&quot;</span>,\n                <span class=\"hljs-string\" class=\"hljs-string\">&quot;Action&quot;</span>: [\n                    <span class=\"hljs-string\" class=\"hljs-string\">&quot;bedrock:InvokeModel&quot;</span>,\n                    <span class=\"hljs-string\" class=\"hljs-string\">&quot;bedrock:InvokeModelWithResponseStream&quot;</span>\n                ],\n                <span class=\"hljs-string\" class=\"hljs-string\">&quot;Resource&quot;</span>: [\n                    <span class=\"hljs-string\" class=\"hljs-string\">&quot;arn:aws:bedrock:*:*:model/anthropic.claude*&quot;</span>,\n                    <span class=\"hljs-string\" class=\"hljs-string\">&quot;arn:aws:bedrock:*:*:model/amazon.titan*&quot;</span>\n                ]\n            },\n            <span class=\"hljs-comment\" class=\"hljs-comment\"># S3 读写权限（存储数据）</span>\n            {\n                <span class=\"hljs-string\" class=\"hljs-string\">&quot;Effect&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;Allow&quot;</span>,\n                <span class=\"hljs-string\" class=\"hljs-string\">&quot;Action&quot;</span>: [\n                    <span class=\"hljs-string\" class=\"hljs-string\">&quot;s3:GetObject&quot;</span>,\n                    <span class=\"hljs-string\" class=\"hljs-string\">&quot;s3:PutObject&quot;</span>, \n                    <span class=\"hljs-string\" class=\"hljs-string\">&quot;s3:DeleteObject&quot;</span>,\n                    <span class=\"hljs-string\" class=\"hljs-string\">&quot;s3:ListBucket&quot;</span>\n                ],\n                <span class=\"hljs-string\" class=\"hljs-string\">&quot;Resource&quot;</span>: [\n                    <span class=\"hljs-string\" class=\"hljs-string\">&quot;arn:aws:s3:::openclaw-data-*/*&quot;</span>,\n                    <span class=\"hljs-string\" class=\"hljs-string\">&quot;arn:aws:s3:::openclaw-data-*&quot;</span>\n                ]\n            },\n            <span class=\"hljs-comment\" class=\"hljs-comment\"># 密钥读取权限</span>\n            {\n                <span class=\"hljs-string\" class=\"hljs-string\">&quot;Effect&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;Allow&quot;</span>,\n                <span class=\"hljs-string\" class=\"hljs-string\">&quot;Action&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;secretsmanager:GetSecretValue&quot;</span>,\n                <span class=\"hljs-string\" class=\"hljs-string\">&quot;Resource&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;arn:aws:secretsmanager:*:*:secret:openclaw/*&quot;</span>\n            },\n            <span class=\"hljs-comment\" class=\"hljs-comment\"># 日志写入权限</span>\n            {\n                <span class=\"hljs-string\" class=\"hljs-string\">&quot;Effect&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;Allow&quot;</span>,\n                <span class=\"hljs-string\" class=\"hljs-string\">&quot;Action&quot;</span>: [\n                    <span class=\"hljs-string\" class=\"hljs-string\">&quot;logs:CreateLogGroup&quot;</span>,\n                    <span class=\"hljs-string\" class=\"hljs-string\">&quot;logs:CreateLogStream&quot;</span>,\n                    <span class=\"hljs-string\" class=\"hljs-string\">&quot;logs:PutLogEvents&quot;</span>\n                ],\n                <span class=\"hljs-string\" class=\"hljs-string\">&quot;Resource&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;arn:aws:logs:*:*:log-group:/openclaw/*&quot;</span>\n            }\n        ]\n    }\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 创建策略</span>\n    response = iam.create_policy(\n        PolicyName=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClawMinimalPolicy&apos;</span>,\n        PolicyDocument=json.dumps(policy_doc),\n        Description=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClaw 最小权限策略，够用就行&apos;</span>\n    )\n    \n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">f&quot;🎉 策略创建成功: <span class=\"hljs-subst\" class=\"hljs-subst\">{response[<span class=\"hljs-string\" class=\"hljs-string\">&apos;Policy&apos;</span>][<span class=\"hljs-string\" class=\"hljs-string\">&apos;Arn&apos;</span>]}</span>&quot;</span>)\n    <span class=\"hljs-keyword\" class=\"hljs-keyword\">return</span> response[<span class=\"hljs-string\" class=\"hljs-string\">&apos;Policy&apos;</span>][<span class=\"hljs-string\" class=\"hljs-string\">&apos;Arn&apos;</span>]\n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># 创建对应的 IAM 角色</span>\n<span class=\"hljs-keyword\" class=\"hljs-keyword\">def</span> <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">create_role</span>(<span class=\"hljs-params\" class=\"hljs-params\">policy_arn</span>):\n    <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;&quot;创建 IAM 角色并绑定策略&quot;&quot;&quot;</span>\n    iam = boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;iam&apos;</span>)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># EC2 可以使用这个角色</span>\n    trust_policy = {\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;Version&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;2012-10-17&quot;</span>,\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;Statement&quot;</span>: [{\n            <span class=\"hljs-string\" class=\"hljs-string\">&quot;Effect&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;Allow&quot;</span>,\n            <span class=\"hljs-string\" class=\"hljs-string\">&quot;Principal&quot;</span>: {<span class=\"hljs-string\" class=\"hljs-string\">&quot;Service&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;ec2.amazonaws.com&quot;</span>},\n            <span class=\"hljs-string\" class=\"hljs-string\">&quot;Action&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;sts:AssumeRole&quot;</span>\n        }]\n    }\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 创建角色</span>\n    iam.create_role(\n        RoleName=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClawRole&apos;</span>,\n        AssumeRolePolicyDocument=json.dumps(trust_policy)\n    )\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 绑定我们的最小权限策略</span>\n    iam.attach_role_policy(\n        RoleName=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClawRole&apos;</span>,\n        PolicyArn=policy_arn\n    )\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 创建实例配置文件（EC2 需要这个）</span>\n    iam.create_instance_profile(InstanceProfileName=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClawProfile&apos;</span>)\n    iam.add_role_to_instance_profile(\n        InstanceProfileName=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClawProfile&apos;</span>,\n        RoleName=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClawRole&apos;</span>\n    )\n    \n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">&quot;✅ IAM 角色设置完毕&quot;</span>)\n\n<span class=\"hljs-keyword\" class=\"hljs-keyword\">if</span> __name__ == <span class=\"hljs-string\" class=\"hljs-string\">&quot;__main__&quot;</span>:\n    policy_arn = create_minimal_policy()\n    create_role(policy_arn)\n</code></pre></div></div><h3 level=\"3\" id=\"权限测试脚本\">权限测试脚本</h3><p>写代码一定要测试，权限配置也一样：</p><div class=\"llt-code readonly\"><div class=\"language\">auto</div><div class=\"wrapper\"><pre><code></code></pre></div></div><div class=\"llt-code readonly\"><div class=\"language\">python</div><div class=\"wrapper\"><pre><code class=\"language-python\"><span class=\"hljs-keyword\" class=\"hljs-keyword\">def</span> <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">test_permissions</span>():\n    <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;&quot;测试权限是否配置正确&quot;&quot;&quot;</span>\n    \n    tests = [\n        <span class=\"hljs-comment\" class=\"hljs-comment\"># 测试 Bedrock</span>\n        {\n            <span class=\"hljs-string\" class=\"hljs-string\">&apos;name&apos;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&apos;Bedrock 权限&apos;</span>,\n            <span class=\"hljs-string\" class=\"hljs-string\">&apos;test&apos;</span>: <span class=\"hljs-keyword\" class=\"hljs-keyword\">lambda</span>: boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;bedrock-runtime&apos;</span>),\n            <span class=\"hljs-string\" class=\"hljs-string\">&apos;should_work&apos;</span>: <span class=\"hljs-literal\" class=\"hljs-literal\">True</span>\n        },\n        <span class=\"hljs-comment\" class=\"hljs-comment\"># 测试 S3</span>\n        {\n            <span class=\"hljs-string\" class=\"hljs-string\">&apos;name&apos;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&apos;S3 权限&apos;</span>,\n            <span class=\"hljs-string\" class=\"hljs-string\">&apos;test&apos;</span>: <span class=\"hljs-keyword\" class=\"hljs-keyword\">lambda</span>: boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;s3&apos;</span>).head_bucket(Bucket=<span class=\"hljs-string\" class=\"hljs-string\">&apos;openclaw-data-test&apos;</span>),\n            <span class=\"hljs-string\" class=\"hljs-string\">&apos;should_work&apos;</span>: <span class=\"hljs-literal\" class=\"hljs-literal\">True</span>\n        },\n        <span class=\"hljs-comment\" class=\"hljs-comment\"># 测试不应该有的权限（比如 EC2）</span>\n        {\n            <span class=\"hljs-string\" class=\"hljs-string\">&apos;name&apos;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&apos;EC2 权限（应该没有）&apos;</span>,\n            <span class=\"hljs-string\" class=\"hljs-string\">&apos;test&apos;</span>: <span class=\"hljs-keyword\" class=\"hljs-keyword\">lambda</span>: boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;ec2&apos;</span>).describe_instances(),\n            <span class=\"hljs-string\" class=\"hljs-string\">&apos;should_work&apos;</span>: <span class=\"hljs-literal\" class=\"hljs-literal\">False</span>\n        }\n    ]\n    \n    <span class=\"hljs-keyword\" class=\"hljs-keyword\">for</span> test <span class=\"hljs-keyword\" class=\"hljs-keyword\">in</span> tests:\n        <span class=\"hljs-keyword\" class=\"hljs-keyword\">try</span>:\n            test[<span class=\"hljs-string\" class=\"hljs-string\">&apos;test&apos;</span>]()\n            result = <span class=\"hljs-string\" class=\"hljs-string\">&quot;✅ 正常&quot;</span> <span class=\"hljs-keyword\" class=\"hljs-keyword\">if</span> test[<span class=\"hljs-string\" class=\"hljs-string\">&apos;should_work&apos;</span>] <span class=\"hljs-keyword\" class=\"hljs-keyword\">else</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;❌ 权限过大&quot;</span>\n        <span class=\"hljs-keyword\" class=\"hljs-keyword\">except</span> Exception <span class=\"hljs-keyword\" class=\"hljs-keyword\">as</span> e:\n            result = <span class=\"hljs-string\" class=\"hljs-string\">&quot;❌ 异常&quot;</span> <span class=\"hljs-keyword\" class=\"hljs-keyword\">if</span> test[<span class=\"hljs-string\" class=\"hljs-string\">&apos;should_work&apos;</span>] <span class=\"hljs-keyword\" class=\"hljs-keyword\">else</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;✅ 正确拒绝&quot;</span>\n        \n        <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">f&quot;<span class=\"hljs-subst\" class=\"hljs-subst\">{test[<span class=\"hljs-string\" class=\"hljs-string\">&apos;name&apos;</span>]}</span>: <span class=\"hljs-subst\" class=\"hljs-subst\">{result}</span>&quot;</span>)\n\ntest_permissions()\n</code></pre></div></div><h2 level=\"2\" id=\"-第二招私有网络部署\">🏠 第二招：私有网络部署</h2><h3 level=\"3\" id=\"搭建安全的-VPC\">搭建安全的 VPC</h3><p>把 OpenClaw 藏到私有子网里，这样就算有漏洞，外网也访问不到：</p><div class=\"llt-code readonly\"><div class=\"language\">auto</div><div class=\"wrapper\"><pre><code></code></pre></div></div><div class=\"llt-code readonly\"><div class=\"language\">python</div><div class=\"wrapper\"><pre><code class=\"language-python\"><span class=\"hljs-keyword\" class=\"hljs-keyword\">def</span> <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">setup_secure_vpc</span>():\n    <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;&quot;搭建安全的 VPC 网络&quot;&quot;&quot;</span>\n    ec2 = boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;ec2&apos;</span>)\n    \n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">&quot;🏗️ 开始搭建 VPC...&quot;</span>)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 1. 创建 VPC</span>\n    vpc = ec2.create_vpc(CidrBlock=<span class=\"hljs-string\" class=\"hljs-string\">&apos;10.0.0.0/16&apos;</span>)\n    vpc_id = vpc[<span class=\"hljs-string\" class=\"hljs-string\">&apos;Vpc&apos;</span>][<span class=\"hljs-string\" class=\"hljs-string\">&apos;VpcId&apos;</span>]\n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">f&quot;✅ VPC 创建完成: <span class=\"hljs-subst\" class=\"hljs-subst\">{vpc_id}</span>&quot;</span>)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 2. 创建子网</span>\n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 私有子网（OpenClaw 住这里）</span>\n    private_subnet = ec2.create_subnet(\n        VpcId=vpc_id,\n        CidrBlock=<span class=\"hljs-string\" class=\"hljs-string\">&apos;10.0.1.0/24&apos;</span>,\n        AvailabilityZone=<span class=\"hljs-string\" class=\"hljs-string\">&apos;us-east-1a&apos;</span>\n    )\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 公网子网（NAT Gateway 住这里）</span>\n    public_subnet = ec2.create_subnet(\n        VpcId=vpc_id,\n        CidrBlock=<span class=\"hljs-string\" class=\"hljs-string\">&apos;10.0.2.0/24&apos;</span>,\n        AvailabilityZone=<span class=\"hljs-string\" class=\"hljs-string\">&apos;us-east-1a&apos;</span>\n    )\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 3. 设置 Internet Gateway（公网访问必须）</span>\n    igw = ec2.create_internet_gateway()\n    igw_id = igw[<span class=\"hljs-string\" class=\"hljs-string\">&apos;InternetGateway&apos;</span>][<span class=\"hljs-string\" class=\"hljs-string\">&apos;InternetGatewayId&apos;</span>]\n    ec2.attach_internet_gateway(InternetGatewayId=igw_id, VpcId=vpc_id)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 4. 创建 NAT Gateway（私有子网上网必须）</span>\n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 先分配一个公网 IP</span>\n    eip = ec2.allocate_address(Domain=<span class=\"hljs-string\" class=\"hljs-string\">&apos;vpc&apos;</span>)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 然后创建 NAT Gateway</span>\n    nat_gw = ec2.create_nat_gateway(\n        SubnetId=public_subnet[<span class=\"hljs-string\" class=\"hljs-string\">&apos;Subnet&apos;</span>][<span class=\"hljs-string\" class=\"hljs-string\">&apos;SubnetId&apos;</span>],\n        AllocationId=eip[<span class=\"hljs-string\" class=\"hljs-string\">&apos;AllocationId&apos;</span>]\n    )\n    nat_gw_id = nat_gw[<span class=\"hljs-string\" class=\"hljs-string\">&apos;NatGateway&apos;</span>][<span class=\"hljs-string\" class=\"hljs-string\">&apos;NatGatewayId&apos;</span>]\n    \n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">&quot;🚪 NAT Gateway 创建完成，私有子网可以上网了&quot;</span>)\n    \n    <span class=\"hljs-keyword\" class=\"hljs-keyword\">return</span> {\n        <span class=\"hljs-string\" class=\"hljs-string\">&apos;vpc_id&apos;</span>: vpc_id,\n        <span class=\"hljs-string\" class=\"hljs-string\">&apos;private_subnet_id&apos;</span>: private_subnet[<span class=\"hljs-string\" class=\"hljs-string\">&apos;Subnet&apos;</span>][<span class=\"hljs-string\" class=\"hljs-string\">&apos;SubnetId&apos;</span>],\n        <span class=\"hljs-string\" class=\"hljs-string\">&apos;public_subnet_id&apos;</span>: public_subnet[<span class=\"hljs-string\" class=\"hljs-string\">&apos;Subnet&apos;</span>][<span class=\"hljs-string\" class=\"hljs-string\">&apos;SubnetId&apos;</span>],\n        <span class=\"hljs-string\" class=\"hljs-string\">&apos;nat_gw_id&apos;</span>: nat_gw_id,\n        <span class=\"hljs-string\" class=\"hljs-string\">&apos;igw_id&apos;</span>: igw_id\n    }\n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># 配置路由（很重要，不然网络不通）</span>\n<span class=\"hljs-keyword\" class=\"hljs-keyword\">def</span> <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">setup_routes</span>(<span class=\"hljs-params\" class=\"hljs-params\">infra</span>):\n    <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;&quot;配置网络路由&quot;&quot;&quot;</span>\n    ec2 = boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;ec2&apos;</span>)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 给私有子网创建路由表</span>\n    private_rt = ec2.create_route_table(VpcId=infra[<span class=\"hljs-string\" class=\"hljs-string\">&apos;vpc_id&apos;</span>])\n    private_rt_id = private_rt[<span class=\"hljs-string\" class=\"hljs-string\">&apos;RouteTable&apos;</span>][<span class=\"hljs-string\" class=\"hljs-string\">&apos;RouteTableId&apos;</span>]\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 私有子网的流量都走 NAT Gateway</span>\n    ec2.create_route(\n        RouteTableId=private_rt_id,\n        DestinationCidrBlock=<span class=\"hljs-string\" class=\"hljs-string\">&apos;0.0.0.0/0&apos;</span>,\n        NatGatewayId=infra[<span class=\"hljs-string\" class=\"hljs-string\">&apos;nat_gw_id&apos;</span>]\n    )\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 把私有子网关联到这个路由表</span>\n    ec2.associate_route_table(\n        RouteTableId=private_rt_id,\n        SubnetId=infra[<span class=\"hljs-string\" class=\"hljs-string\">&apos;private_subnet_id&apos;</span>]\n    )\n    \n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">&quot;🛣️ 网络路由配置完成&quot;</span>)\n</code></pre></div></div><h3 level=\"3\" id=\"Security-Group-配置\">Security Group 配置</h3><p>安全组就是防火墙，只开必要的端口：</p><div class=\"llt-code readonly\"><div class=\"language\">auto</div><div class=\"wrapper\"><pre><code></code></pre></div></div><div class=\"llt-code readonly\"><div class=\"language\">python</div><div class=\"wrapper\"><pre><code class=\"language-python\"><span class=\"hljs-keyword\" class=\"hljs-keyword\">def</span> <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">create_security_group</span>(<span class=\"hljs-params\" class=\"hljs-params\">vpc_id</span>):\n    <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;&quot;创建 OpenClaw 专用安全组&quot;&quot;&quot;</span>\n    ec2 = boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;ec2&apos;</span>)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 创建安全组</span>\n    sg = ec2.create_security_group(\n        GroupName=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClawSecure&apos;</span>,\n        Description=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClaw 安全组 - 只开必要端口&apos;</span>,\n        VpcId=vpc_id\n    )\n    sg_id = sg[<span class=\"hljs-string\" class=\"hljs-string\">&apos;GroupId&apos;</span>]\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 入站规则：只允许必要的访问</span>\n    ec2.authorize_security_group_ingress(\n        GroupId=sg_id,\n        IpPermissions=[\n            <span class=\"hljs-comment\" class=\"hljs-comment\"># SSH 访问（只允许 VPC 内部）</span>\n            {\n                <span class=\"hljs-string\" class=\"hljs-string\">&apos;IpProtocol&apos;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&apos;tcp&apos;</span>,\n                <span class=\"hljs-string\" class=\"hljs-string\">&apos;FromPort&apos;</span>: <span class=\"hljs-number\" class=\"hljs-number\">22</span>,\n                <span class=\"hljs-string\" class=\"hljs-string\">&apos;ToPort&apos;</span>: <span class=\"hljs-number\" class=\"hljs-number\">22</span>,\n                <span class=\"hljs-string\" class=\"hljs-string\">&apos;IpRanges&apos;</span>: [{<span class=\"hljs-string\" class=\"hljs-string\">&apos;CidrIp&apos;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&apos;10.0.0.0/16&apos;</span>}]\n            },\n            <span class=\"hljs-comment\" class=\"hljs-comment\"># OpenClaw 端口（只允许 VPC 内部）</span>\n            {\n                <span class=\"hljs-string\" class=\"hljs-string\">&apos;IpProtocol&apos;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&apos;tcp&apos;</span>,\n                <span class=\"hljs-string\" class=\"hljs-string\">&apos;FromPort&apos;</span>: <span class=\"hljs-number\" class=\"hljs-number\">8080</span>,\n                <span class=\"hljs-string\" class=\"hljs-string\">&apos;ToPort&apos;</span>: <span class=\"hljs-number\" class=\"hljs-number\">8080</span>,\n                <span class=\"hljs-string\" class=\"hljs-string\">&apos;IpRanges&apos;</span>: [{<span class=\"hljs-string\" class=\"hljs-string\">&apos;CidrIp&apos;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&apos;10.0.0.0/16&apos;</span>}]\n            }\n        ]\n    )\n    \n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">f&quot;🛡️ 安全组创建完成: <span class=\"hljs-subst\" class=\"hljs-subst\">{sg_id}</span>&quot;</span>)\n    <span class=\"hljs-keyword\" class=\"hljs-keyword\">return</span> sg_id\n</code></pre></div></div><h2 level=\"2\" id=\"-第三招密钥管理升级\">🔐 第三招：密钥管理升级</h2><h3 level=\"3\" id=\"用-Secrets-Manager-管理密钥\">用 Secrets Manager 管理密钥</h3><p>以前 API Key 直接写在配置文件里，现在用亚马逊云科技的密钥管理服务：</p><div class=\"llt-code readonly\"><div class=\"language\">auto</div><div class=\"wrapper\"><pre><code></code></pre></div></div><div class=\"llt-code readonly\"><div class=\"language\">python</div><div class=\"wrapper\"><pre><code class=\"language-python\"><span class=\"hljs-keyword\" class=\"hljs-keyword\">def</span> <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">setup_secret_management</span>():\n    <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;&quot;设置密钥管理&quot;&quot;&quot;</span>\n    secrets = boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;secretsmanager&apos;</span>)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 创建密钥</span>\n    secret_data = {\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;bedrock_api_key&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;your-actual-bedrock-key&quot;</span>,\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;openai_api_key&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;backup-openai-key&quot;</span>,  <span class=\"hljs-comment\" class=\"hljs-comment\"># 备用密钥</span>\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;database_password&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;super-secure-password&quot;</span>\n    }\n    \n    secrets.create_secret(\n        Name=<span class=\"hljs-string\" class=\"hljs-string\">&apos;openclaw/prod/api-keys&apos;</span>,\n        Description=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClaw 生产环境 API 密钥&apos;</span>,\n        SecretString=json.dumps(secret_data)\n    )\n    \n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">&quot;🔑 密钥管理设置完成&quot;</span>)\n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># OpenClaw 代码中这样读取密钥</span>\n<span class=\"hljs-keyword\" class=\"hljs-keyword\">def</span> <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">get_api_key</span>(<span class=\"hljs-params\" class=\"hljs-params\">key_name</span>):\n    <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;&quot;安全地获取 API 密钥&quot;&quot;&quot;</span>\n    secrets = boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;secretsmanager&apos;</span>)\n    \n    <span class=\"hljs-keyword\" class=\"hljs-keyword\">try</span>:\n        response = secrets.get_secret_value(\n            SecretId=<span class=\"hljs-string\" class=\"hljs-string\">&apos;openclaw/prod/api-keys&apos;</span>\n        )\n        all_secrets = json.loads(response[<span class=\"hljs-string\" class=\"hljs-string\">&apos;SecretString&apos;</span>])\n        <span class=\"hljs-keyword\" class=\"hljs-keyword\">return</span> all_secrets.get(key_name)\n    <span class=\"hljs-keyword\" class=\"hljs-keyword\">except</span> Exception <span class=\"hljs-keyword\" class=\"hljs-keyword\">as</span> e:\n        <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">f&quot;❌ 获取密钥失败: <span class=\"hljs-subst\" class=\"hljs-subst\">{e}</span>&quot;</span>)\n        <span class=\"hljs-keyword\" class=\"hljs-keyword\">return</span> <span class=\"hljs-literal\" class=\"hljs-literal\">None</span>\n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># 使用示例</span>\nbedrock_key = get_api_key(<span class=\"hljs-string\" class=\"hljs-string\">&apos;bedrock_api_key&apos;</span>)\n<span class=\"hljs-keyword\" class=\"hljs-keyword\">if</span> bedrock_key:\n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">&quot;✅ 密钥获取成功&quot;</span>)\n<span class=\"hljs-keyword\" class=\"hljs-keyword\">else</span>:\n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">&quot;❌ 密钥获取失败&quot;</span>)\n</code></pre></div></div><h2 level=\"2\" id=\"-第四招审计日志全覆盖\">📊 第四招：审计日志全覆盖</h2><h3 level=\"3\" id=\"设置-CloudTrail-和-CloudWatch\">设置 CloudTrail 和 CloudWatch</h3><p>出了问题要能查到是谁干的，这就需要日志记录：</p><div class=\"llt-code readonly\"><div class=\"language\">auto</div><div class=\"wrapper\"><pre><code></code></pre></div></div><div class=\"llt-code readonly\"><div class=\"language\">python</div><div class=\"wrapper\"><pre><code class=\"language-python\"><span class=\"hljs-keyword\" class=\"hljs-keyword\">def</span> <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">setup_audit_logging</span>():\n    <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;&quot;设置审计日志&quot;&quot;&quot;</span>\n    cloudtrail = boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;cloudtrail&apos;</span>)\n    logs = boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;logs&apos;</span>)\n    s3 = boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;s3&apos;</span>)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 1. 创建 S3 桶存储 CloudTrail 日志</span>\n    bucket_name = <span class=\"hljs-string\" class=\"hljs-string\">f&apos;openclaw-audit-logs-<span class=\"hljs-subst\" class=\"hljs-subst\">{<span class=\"hljs-built_in\" class=\"hljs-built_in\">int</span>(time.time())}</span>&apos;</span>  <span class=\"hljs-comment\" class=\"hljs-comment\"># 唯一桶名</span>\n    s3.create_bucket(Bucket=bucket_name)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 设置桶策略（让 CloudTrail 能写入）</span>\n    bucket_policy = {\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;Version&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;2012-10-17&quot;</span>,\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;Statement&quot;</span>: [{\n            <span class=\"hljs-string\" class=\"hljs-string\">&quot;Effect&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;Allow&quot;</span>,\n            <span class=\"hljs-string\" class=\"hljs-string\">&quot;Principal&quot;</span>: {<span class=\"hljs-string\" class=\"hljs-string\">&quot;Service&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;cloudtrail.amazonaws.com&quot;</span>},\n            <span class=\"hljs-string\" class=\"hljs-string\">&quot;Action&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&quot;s3:PutObject&quot;</span>,\n            <span class=\"hljs-string\" class=\"hljs-string\">&quot;Resource&quot;</span>: <span class=\"hljs-string\" class=\"hljs-string\">f&quot;arn:aws:s3:::<span class=\"hljs-subst\" class=\"hljs-subst\">{bucket_name}</span>/*&quot;</span>\n        }]\n    }\n    \n    s3.put_bucket_policy(\n        Bucket=bucket_name,\n        Policy=json.dumps(bucket_policy)\n    )\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 2. 创建 CloudTrail</span>\n    cloudtrail.create_trail(\n        Name=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClawAuditTrail&apos;</span>,\n        S3BucketName=bucket_name,\n        IncludeGlobalServiceEvents=<span class=\"hljs-literal\" class=\"hljs-literal\">True</span>,\n        IsMultiRegionTrail=<span class=\"hljs-literal\" class=\"hljs-literal\">True</span>\n    )\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 启动日志记录</span>\n    cloudtrail.start_logging(Name=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClawAuditTrail&apos;</span>)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 3. 创建 CloudWatch 日志组（应用日志）</span>\n    logs.create_log_group(\n        logGroupName=<span class=\"hljs-string\" class=\"hljs-string\">&apos;/openclaw/app-logs&apos;</span>,\n        tags={<span class=\"hljs-string\" class=\"hljs-string\">&apos;Environment&apos;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&apos;prod&apos;</span>, <span class=\"hljs-string\" class=\"hljs-string\">&apos;Component&apos;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&apos;openclaw&apos;</span>}\n    )\n    \n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">&quot;📋 审计日志设置完成&quot;</span>)\n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">f&quot;   - API 调用日志: S3 桶 <span class=\"hljs-subst\" class=\"hljs-subst\">{bucket_name}</span>&quot;</span>)\n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">&quot;   - 应用日志: CloudWatch Logs /openclaw/app-logs&quot;</span>)\n</code></pre></div></div><h2 level=\"2\" id=\"-第五招自动安全检查\">🤖 第五招：自动安全检查</h2><h3 level=\"3\" id=\"Lambda-安全扫描器\">Lambda 安全扫描器</h3><p>写个 Lambda 函数定期检查安全配置，有问题自动告警：</p><div class=\"llt-code readonly\"><div class=\"language\">auto</div><div class=\"wrapper\"><pre><code></code></pre></div></div><div class=\"llt-code readonly\"><div class=\"language\">python</div><div class=\"wrapper\"><pre><code class=\"language-python\"><span class=\"hljs-keyword\" class=\"hljs-keyword\">def</span> <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">security_scanner_lambda</span>():\n    <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;&quot;Lambda 安全扫描器代码&quot;&quot;&quot;</span>\n    lambda_code = <span class=\"hljs-string\" class=\"hljs-string\">&apos;&apos;&apos;\nimport boto3\nimport json\n\ndef lambda_handler(event, context):\n    &quot;&quot;&quot;定期安全检查&quot;&quot;&quot;\n    ec2 = boto3.client(&apos;ec2&apos;)\n    sns = boto3.client(&apos;sns&apos;)\n    \n    risks = []\n    \n    # 检查所有安全组\n    for sg in ec2.describe_security_groups()[&apos;SecurityGroups&apos;]:\n        # 跳过默认安全组\n        if sg[&apos;GroupName&apos;] == &apos;default&apos;:\n            continue\n            \n        # 检查是否有危险的开放端口\n        for rule in sg[&apos;IpPermissions&apos;]:\n            for ip_range in rule.get(&apos;IpRanges&apos;, []):\n                if ip_range.get(&apos;CidrIp&apos;) == &apos;0.0.0.0/0&apos;:\n                    # 只允许 HTTP/HTTPS 对外开放\n                    port = rule.get(&apos;FromPort&apos;, 0)\n                    if port not in [80, 443]:\n                        risks.append({\n                            &apos;type&apos;: &apos;危险端口开放&apos;,\n                            &apos;resource&apos;: sg[&apos;GroupId&apos;],\n                            &apos;detail&apos;: f&apos;端口 {port} 对全网开放&apos;,\n                            &apos;severity&apos;: &apos;HIGH&apos;\n                        })\n    \n    # 如果有风险，发送告警\n    if risks:\n        message = {\n            &apos;timestamp&apos;: context.aws_request_id,\n            &apos;risks_found&apos;: len(risks),\n            &apos;details&apos;: risks\n        }\n        \n        sns.publish(\n            TopicArn=&apos;arn:aws:sns:us-east-1:123456789:openclaw-alerts&apos;,\n            Message=json.dumps(message, indent=2),\n            Subject=f&apos;🚨 OpenClaw 安全风险告警 ({len(risks)} 个问题)&apos;\n        )\n    \n    return {\n        &apos;statusCode&apos;: 200,\n        &apos;body&apos;: json.dumps({\n            &apos;risks_found&apos;: len(risks),\n            &apos;message&apos;: &apos;安全检查完成&apos; if not risks else &apos;发现安全风险&apos;\n        })\n    }\n    &apos;&apos;&apos;</span>\n    \n    <span class=\"hljs-keyword\" class=\"hljs-keyword\">return</span> lambda_code\n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># 部署 Lambda 函数</span>\n<span class=\"hljs-keyword\" class=\"hljs-keyword\">def</span> <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">deploy_security_scanner</span>():\n    <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;&quot;部署安全扫描器&quot;&quot;&quot;</span>\n    lambda_client = boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;lambda&apos;</span>)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 创建 ZIP 包</span>\n    <span class=\"hljs-keyword\" class=\"hljs-keyword\">import</span> zipfile\n    <span class=\"hljs-keyword\" class=\"hljs-keyword\">import</span> tempfile\n    \n    <span class=\"hljs-keyword\" class=\"hljs-keyword\">with</span> tempfile.NamedTemporaryFile(suffix=<span class=\"hljs-string\" class=\"hljs-string\">&apos;.zip&apos;</span>, delete=<span class=\"hljs-literal\" class=\"hljs-literal\">False</span>) <span class=\"hljs-keyword\" class=\"hljs-keyword\">as</span> tmp:\n        <span class=\"hljs-keyword\" class=\"hljs-keyword\">with</span> zipfile.ZipFile(tmp.name, <span class=\"hljs-string\" class=\"hljs-string\">&apos;w&apos;</span>) <span class=\"hljs-keyword\" class=\"hljs-keyword\">as</span> z:\n            z.writestr(<span class=\"hljs-string\" class=\"hljs-string\">&apos;lambda_function.py&apos;</span>, security_scanner_lambda())\n        \n        <span class=\"hljs-comment\" class=\"hljs-comment\"># 部署函数</span>\n        <span class=\"hljs-keyword\" class=\"hljs-keyword\">with</span> <span class=\"hljs-built_in\" class=\"hljs-built_in\">open</span>(tmp.name, <span class=\"hljs-string\" class=\"hljs-string\">&apos;rb&apos;</span>) <span class=\"hljs-keyword\" class=\"hljs-keyword\">as</span> zip_file:\n            lambda_client.create_function(\n                FunctionName=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClawSecurityScanner&apos;</span>,\n                Runtime=<span class=\"hljs-string\" class=\"hljs-string\">&apos;python3.9&apos;</span>,\n                Role=<span class=\"hljs-string\" class=\"hljs-string\">&apos;arn:aws:iam::YOUR-ACCOUNT:role/OpenClawScannerRole&apos;</span>,\n                Handler=<span class=\"hljs-string\" class=\"hljs-string\">&apos;lambda_function.lambda_handler&apos;</span>,\n                Code={<span class=\"hljs-string\" class=\"hljs-string\">&apos;ZipFile&apos;</span>: zip_file.read()},\n                Timeout=<span class=\"hljs-number\" class=\"hljs-number\">60</span>\n            )\n    \n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">&quot;🤖 安全扫描器部署完成&quot;</span>)\n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># 设置定时任务（每天检查一次）</span>\n<span class=\"hljs-keyword\" class=\"hljs-keyword\">def</span> <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">setup_scheduler</span>():\n    <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;&quot;设置定时扫描&quot;&quot;&quot;</span>\n    events = boto3.client(<span class=\"hljs-string\" class=\"hljs-string\">&apos;events&apos;</span>)\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 创建定时规则（每天上午 9 点）</span>\n    events.put_rule(\n        Name=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClawSecurityCheck&apos;</span>,\n        Description=<span class=\"hljs-string\" class=\"hljs-string\">&apos;每日安全检查&apos;</span>,\n        ScheduleExpression=<span class=\"hljs-string\" class=\"hljs-string\">&apos;cron(0 9 * * ? *)&apos;</span>  <span class=\"hljs-comment\" class=\"hljs-comment\"># 上午 9 点</span>\n    )\n    \n    <span class=\"hljs-comment\" class=\"hljs-comment\"># 关联到 Lambda 函数</span>\n    events.put_targets(\n        Rule=<span class=\"hljs-string\" class=\"hljs-string\">&apos;OpenClawSecurityCheck&apos;</span>,\n        Targets=[{\n            <span class=\"hljs-string\" class=\"hljs-string\">&apos;Id&apos;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&apos;1&apos;</span>,\n            <span class=\"hljs-string\" class=\"hljs-string\">&apos;Arn&apos;</span>: <span class=\"hljs-string\" class=\"hljs-string\">&apos;arn:aws:lambda:us-east-1:YOUR-ACCOUNT:function:OpenClawSecurityScanner&apos;</span>\n        }]\n    )\n    \n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">&quot;⏰ 定时安全检查设置完成&quot;</span>)\n</code></pre></div></div><h2 level=\"2\" id=\"-一键部署脚本\">🚀 一键部署脚本</h2><p>把所有步骤串起来，写个一键部署脚本：</p><div class=\"llt-code readonly\"><div class=\"language\">auto</div><div class=\"wrapper\"><pre><code></code></pre></div></div><div class=\"llt-code readonly\"><div class=\"language\">bash</div><div class=\"wrapper\"><pre><code class=\"language-bash\"><span class=\"hljs-meta\" class=\"hljs-meta\">#!/bin/bash</span>\n<span class=\"hljs-comment\" class=\"hljs-comment\"># 🚀 OpenClaw 安全部署一键脚本</span>\n\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">set</span> -e  <span class=\"hljs-comment\" class=\"hljs-comment\"># 出错就停止</span>\n\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;🦞 开始部署 OpenClaw 安全架构...&quot;</span>\n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># Step 1: IAM 权限</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;👤 创建 IAM 策略和角色...&quot;</span>\npython3 setup_iam.py\n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># Step 2: VPC 网络</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;🏠 搭建 VPC 网络...&quot;</span>  \npython3 setup_vpc.py\n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># Step 3: 密钥管理</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;🔐 设置密钥管理...&quot;</span>\npython3 setup_secrets.py\n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># Step 4: 审计日志</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;📊 配置审计日志...&quot;</span>\npython3 setup_logging.py  \n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># Step 5: 安全扫描</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;🤖 部署安全扫描器...&quot;</span>\npython3 deploy_scanner.py\n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># Step 6: 启动 OpenClaw</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;🦞 启动 OpenClaw 实例...&quot;</span>\naws ec2 run-instances \\\n    --image-id ami-0abcdef1234567890 \\\n    --instance-type t3.medium \\\n    --key-name your-key \\\n    --security-group-ids <span class=\"hljs-variable\" class=\"hljs-variable\">$SECURITY_GROUP_ID</span> \\\n    --subnet-id <span class=\"hljs-variable\" class=\"hljs-variable\">$PRIVATE_SUBNET_ID</span> \\\n    --iam-instance-profile Name=OpenClawProfile \\\n    --user-data file://install-openclaw.sh\n\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;✅ 部署完成！&quot;</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;📋 接下来要做的事：&quot;</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;  1. 等待 EC2 实例启动完成&quot;</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;  2. 通过跳板机 SSH 到 OpenClaw 服务器&quot;</span>  \n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;  3. 检查 OpenClaw 服务状态&quot;</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;  4. 验证权限配置正确&quot;</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;  5. 测试安全扫描器功能&quot;</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">echo</span> <span class=\"hljs-string\" class=\"hljs-string\">&quot;🎉 现在你的 OpenClaw 既安全又好用！&quot;</span>\n</code></pre></div></div><h2 level=\"2\" id=\"-验证和测试\">🎯 验证和测试</h2><p>部署完了不测试等于白干，来验证一下效果：</p><h3 level=\"3\" id=\"安全检查清单\">安全检查清单</h3><div class=\"llt-code readonly\"><div class=\"language\">auto</div><div class=\"wrapper\"><pre><code></code></pre></div></div><div class=\"llt-code readonly\"><div class=\"language\">python</div><div class=\"wrapper\"><pre><code class=\"language-python\"><span class=\"hljs-keyword\" class=\"hljs-keyword\">def</span> <span class=\"hljs-title,function_\" class=\"hljs-title,function_\">security_checklist</span>():\n    <span class=\"hljs-string\" class=\"hljs-string\">&quot;&quot;&quot;安全检查清单&quot;&quot;&quot;</span>\n    checks = [\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;✅ IAM 权限：只有 Bedrock + S3 + Secrets + Logs&quot;</span>,\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;✅ 网络隔离：OpenClaw 在私有子网&quot;</span>, \n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;✅ 端口限制：Security Group 只开 22 和 8080&quot;</span>,\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;✅ 密钥管理：API Key 存在 Secrets Manager&quot;</span>,\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;✅ 审计日志：CloudTrail + CloudWatch 正常记录&quot;</span>, \n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;✅ 自动检查：Lambda 扫描器每日运行&quot;</span>,\n        <span class=\"hljs-string\" class=\"hljs-string\">&quot;✅ 监控告警：有风险自动通知&quot;</span>\n    ]\n    \n    <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">&quot;🔍 安全配置检查清单：&quot;</span>)\n    <span class=\"hljs-keyword\" class=\"hljs-keyword\">for</span> check <span class=\"hljs-keyword\" class=\"hljs-keyword\">in</span> checks:\n        <span class=\"hljs-built_in\" class=\"hljs-built_in\">print</span>(<span class=\"hljs-string\" class=\"hljs-string\">f&quot;  <span class=\"hljs-subst\" class=\"hljs-subst\">{check}</span>&quot;</span>)\n\nsecurity_checklist()\n</code></pre></div></div><h3 level=\"3\" id=\"成本预估\">成本预估</h3><p>别忘了算成本，老板最关心这个：</p><div class=\"llt-code readonly\"><div class=\"language\">auto</div><div class=\"wrapper\"><pre><code></code></pre></div></div><div class=\"llt-code readonly\"><div class=\"language\">markdown</div><div class=\"wrapper\"><pre><code class=\"language-markdown\">💰 每月成本预估：\n<span class=\"hljs-bullet\" class=\"hljs-bullet\">-</span> EC2 t3.medium (私有子网): ~$30\n<span class=\"hljs-bullet\" class=\"hljs-bullet\">-</span> NAT Gateway: ~$32  \n<span class=\"hljs-bullet\" class=\"hljs-bullet\">-</span> CloudTrail: ~$2\n<span class=\"hljs-bullet\" class=\"hljs-bullet\">-</span> CloudWatch Logs: ~$5\n<span class=\"hljs-bullet\" class=\"hljs-bullet\">-</span> Secrets Manager: ~$0.4\n<span class=\"hljs-section\" class=\"hljs-section\">- Lambda (安全扫描): ~$0.1\n--------------------------</span>\n总计: ~$70/月\n</code></pre></div></div><h2 level=\"2\" id=\"-总结\">🎉 总结</h2><p>这套安全方案下来，OpenClaw 的安全等级提升了不止一个档次：</p><h3 level=\"3\" id=\"-解决的问题\">✅ 解决的问题</h3><ul><li><p><strong>权限过大</strong> → IAM 最小权限策略</p></li><li><p><strong>网络暴露</strong> → VPC 私有子网部署</p></li><li><p><strong>密钥泄露</strong> → Secrets Manager 统一管理</p></li><li><p><strong>缺乏审计</strong> → CloudTrail + CloudWatch 全记录</p></li><li><p><strong>被动响应</strong> → Lambda 主动扫描 + 自动告警</p></li></ul><h3 level=\"3\" id=\"\"></h3><script type=\"module\">const injectHtml = (root, html) => {\n  const iframe = document.createElement(\"iframe\");\n  const htmlContent = `<html><head></head><body>${html}</body></html>`;\n  iframe.style.width = \"100%\";\n  iframe.style.height = \"100%\";\n  iframe.onload = () => {\n    const doc = iframe.contentDocument || iframe.contentWindow?.document;\n    if (!doc) {\n      return;\n    }\n    doc.open();\n    doc.write(htmlContent);\n    doc.close();\n  };\n  root.replaceChildren(iframe);\n}\n  document.querySelectorAll('.playground')?.forEach(el=>{\n    const html = el.getAttribute('data-html');\n    if (html) {\n      injectHtml(el,html);\n    }\n    const indicator = document.createElement(\"div\");\n    indicator.className = \"indicator\";\n    const showCode = document.createElement(\"div\");\n    showCode.className = \"show-code\";\n    showCode.innerText = \"code\";\n    showCode.onclick = () => {\n      el.parentElement.classList.remove(\"preview-only\");\n    };\n    const showPreview = document.createElement(\"div\");\n    showPreview.className = \"show-preview\";\n    showPreview.innerText = \"preview\";\n    showPreview.onclick = () => {\n      el.parentElement.classList.add(\"preview-only\");\n    };\n    indicator.appendChild(showCode);\n    indicator.appendChild(showPreview);\n    el.parentElement.appendChild(indicator);\n    if (window.screen.width < 768) {\n      showPreview.click();\n    }\n  });</script>","id":"OpenClaw权限太大","path":"/posts/OpenClaw权限太大.json"}