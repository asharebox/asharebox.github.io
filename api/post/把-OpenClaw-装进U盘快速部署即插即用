{"content":"{\"__ud_title\":\"把 OpenClaw 装进U盘，快速部署即插即用\",\"__ud_tags\":[],\"__ud_update_time\":1777420258774,\"__ud_create_time\":1777420256641,\"__ud_draft\":false,\"type\":\"doc\",\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":1,\"id\":\"指南Zhinan\"},\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"把 OpenClaw 装进U盘，快速部署即插即用\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"使用 dongsheng123132 的项目，一键制作龙虾U盘吧。\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"通过 \"},{\"type\":\"text\",\"marks\":[{\"type\":\"link\",\"attrs\":{\"href\":\"https://github.com/dongsheng123132/u-claw\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer nofollow\",\"class\":null}},{\"type\":\"underline\"}],\"text\":\"GitHub\"},{\"type\":\"text\",\"text\":\" 的 U-Claw 达成把 OpenClaw 装进u盘里，做成 U 盘可插任意电脑，双击即用，便携虾！\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"两种 U 盘模式\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"便携版 U 盘Linux 启动盘原理\"},{\"type\":\"text\",\"text\":\"在已有系统（Mac/Win/Linux）上运行 U 盘里的脚本从 U 盘启动整个 Linux 系统 + OpenClaw\"},{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"U 盘要求\"},{\"type\":\"text\",\"text\":\"4GB+\"},{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"64GB+ USB 3.0\"},{\"type\":\"text\",\"text\":\"（USB 2.0 太慢不推荐）\"},{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"依赖\"},{\"type\":\"text\",\"text\":\"电脑已有操作系统不依赖任何已装系统\"},{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"适合\"},{\"type\":\"text\",\"text\":\"临时用、公共电脑、演示专用 AI 工作站、无系统裸机\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"下面为该项目的部署教程：\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"快速开始制作便携版-U-盘\"},\"content\":[{\"type\":\"text\",\"text\":\"快速开始：制作便携版 U 盘\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"# 1. 克隆代码\\ngit clone https://github.com/dongsheng123132/u-claw.git\\n\\n# 2. 补齐大依赖（Node.js + OpenClaw，国内镜像，约 1 分钟）\\ncd u-claw/portable && bash setup.sh\\n\\n# 3. 拷贝到 U 盘\\ncp -R portable/ /Volumes/你的U盘/U-Claw/   # Mac\\n# 或 Windows 资源管理器直接拖过去\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"完成！\"},{\"type\":\"text\",\"text\":\" 插上 U 盘，双击启动脚本就能用。\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"制作-Linux-启动盘\"},\"content\":[{\"type\":\"text\",\"text\":\"制作 Linux 启动盘\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"把整个 Linux 系统 + OpenClaw 刻在 U 盘，开机从 USB 启动直接进入 AI 助手桌面。\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"准备：\"}]},{\"type\":\"bulletList\",\"content\":[{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"64GB+ USB 3.0 U 盘\"},{\"type\":\"text\",\"text\":\"（推荐三星 BAR Plus、闪迪 CZ880 等高速盘）\"}]}]},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"Linux Mint ISO（\"},{\"type\":\"text\",\"marks\":[{\"type\":\"link\",\"attrs\":{\"href\":\"https://mirrors.tuna.tsinghua.edu.cn/linuxmint-cd/stable/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer nofollow\",\"class\":null}},{\"type\":\"underline\"}],\"text\":\"清华镜像\"},{\"type\":\"text\",\"text\":\" / \"},{\"type\":\"text\",\"marks\":[{\"type\":\"link\",\"attrs\":{\"href\":\"https://mirrors.ustc.edu.cn/linuxmint-cd/stable/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer nofollow\",\"class\":null}},{\"type\":\"underline\"}],\"text\":\"中科大镜像\"},{\"type\":\"text\",\"text\":\"）\"}]}]},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"Rufus v4.0+（\"},{\"type\":\"text\",\"marks\":[{\"type\":\"link\",\"attrs\":{\"href\":\"https://rufus.ie/zh/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer nofollow\",\"class\":null}},{\"type\":\"underline\"}],\"text\":\"rufus.ie\"},{\"type\":\"text\",\"text\":\"）\"}]}]}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"步骤：\"}]},{\"type\":\"orderedList\",\"attrs\":{\"start\":1,\"type\":null},\"content\":[{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"Rufus 刻录 ISO → 开启 \"},{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"Persistent Storage\"},{\"type\":\"text\",\"text\":\"（8-16GB）\"}]}]},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"USB 启动 → 进入 Linux Mint 桌面 → 连网\"}]}]},{\"type\":\"listItem\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"运行安装脚本：\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"curl -O https://raw.githubusercontent.com/dongsheng123132/u-claw/main/portable/setup-linux-usb.sh\\nbash setup-linux-usb.sh\"}]}]}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"详细图文教程见 \"},{\"type\":\"text\",\"marks\":[{\"type\":\"link\",\"attrs\":{\"href\":\"https://u-claw.org/guide.html\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer nofollow\",\"class\":null}},{\"type\":\"underline\"}],\"text\":\"guide.html → Linux 启动盘模式\"},{\"type\":\"text\",\"text\":\"。\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"U-盘功能一览\"},\"content\":[{\"type\":\"text\",\"text\":\"U 盘功能一览\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"功能MacWindowsLinux免安装运行\"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"Mac-Start.commandWindows-Start.batbash Linux-Start.sh\"},{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"功能菜单\"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"Mac-Menu.commandWindows-Menu.batbash Linux-Menu.sh\"},{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"安装到电脑\"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"Mac-Install.commandWindows-Install.batbash Linux-Install.sh\"},{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"首次配置\"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"Config.htmlConfig.htmlConfig.html\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"U-盘文件结构\"},\"content\":[{\"type\":\"text\",\"text\":\"U 盘文件结构\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"U-Claw/                          ← 整个拷到 U 盘\\n├── Mac-Start.command             Mac 免安装运行\\n├── Mac-Menu.command              Mac 功能菜单\\n├── Mac-Install.command           安装到 Mac\\n├── Windows-Start.bat             Windows 免安装运行\\n├── Windows-Menu.bat              Windows 功能菜单\\n├── Windows-Install.bat           安装到 Windows\\n├── Linux-Start.sh                Linux 免安装运行\\n├── Linux-Menu.sh                 Linux 功能菜单\\n├── Linux-Install.sh              安装到 Linux\\n├── setup-linux-usb.sh            Linux 启动盘内安装 OpenClaw\\n├── Config.html                   首次配置页面\\n├── setup.sh                      补齐依赖（开发者用）\\n├── app/                          ← 大依赖（setup.sh 下载，不进 git）\\n│   ├── core/                        OpenClaw + QQ 插件\\n│   └── runtime/\\n│       ├── node-mac-arm64/          Mac Apple Silicon\\n│       ├── node-win-x64/           Windows 64-bit\\n│       └── node-linux-x64/         Linux x86_64\\n└── data/                         ← 用户数据（不进 git）\\n    ├── .openclaw/                   配置文件\\n    ├── memory/                      AI 记忆\\n    └── backups/                     备份\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"桌面安装版Electron-App\"},\"content\":[{\"type\":\"text\",\"text\":\"桌面安装版（Electron App）\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"除了 U 盘便携版，还有桌面 App 版本：\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"cd u-claw-app\\nbash setup.sh            # 一键安装开发环境（国内镜像）\\nnpm run dev              # 开发模式运行\\nnpm run build:mac-arm64  # 打包 → release/*.dmg\\nnpm run build:win        # 打包 → release/*.exe\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"支持的-AI-模型\"},\"content\":[{\"type\":\"text\",\"text\":\"支持的 AI 模型\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"国产模型（无需翻墙）：\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"模型推荐场景\"},{\"type\":\"text\",\"text\":\"DeepSeek编程首选，极便宜Kimi K2.5长文档，256K 上下文通义千问 Qwen免费额度大智谱 GLM学术场景MiniMax语音多模态豆包 Doubao火山引擎\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"国际模型：\"},{\"type\":\"text\",\"text\":\" Claude · GPT · Gemini（需翻墙或中转）\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"支持的聊天平台\"},\"content\":[{\"type\":\"text\",\"text\":\"支持的聊天平台\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"平台状态说明\"},{\"type\":\"text\",\"text\":\"QQ✅ 已预装输入 AppID + Secret 即可飞书✅ 内置企业首选Telegram✅ 内置海外推荐WhatsApp✅ 内置Baileys 协议Discord✅ 内置—微信✅ 社区插件iPad 协议\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"国内镜像\"},\"content\":[{\"type\":\"text\",\"text\":\"国内镜像\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"所有脚本默认走国内镜像，无需翻墙：\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"资源镜像\"},{\"type\":\"text\",\"text\":\"npm 包\"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"registry.npmmirror.com\"},{\"type\":\"text\",\"text\":\"Node.js\"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"npmmirror.com/mirrors/node\"},{\"type\":\"text\",\"text\":\"Electron\"},{\"type\":\"text\",\"marks\":[{\"type\":\"code\"}],\"text\":\"npmmirror.com/mirrors/electron\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":3,\"id\":\"开发--贡献\"},\"content\":[{\"type\":\"text\",\"text\":\"开发 & 贡献\"}]},{\"type\":\"codeBlock\",\"attrs\":{\"language\":null},\"content\":[{\"type\":\"text\",\"text\":\"git clone https://github.com/dongsheng123132/u-claw.git\\ncd u-claw/portable && bash setup.sh\\nbash Mac-Start.command   # Mac 测试\\nbash Linux-Start.sh      # Linux 测试\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"平台支持：\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"bold\"}],\"text\":\"平台状态\"},{\"type\":\"text\",\"text\":\"Mac Apple Silicon (M1-M4)✅Linux x86_64✅Linux ARM64✅Windows x64🚧 开发中Mac Intel❌ 暂不支持\"}]},{\"type\":\"heading\",\"attrs\":{\"level\":2,\"id\":\"相关链接\"},\"content\":[{\"type\":\"text\",\"text\":\"相关链接\"}]},{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"marks\":[{\"type\":\"link\",\"attrs\":{\"href\":\"https://www.u-claw.org/guide.html\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer nofollow\",\"class\":null}},{\"type\":\"underline\"}],\"text\":\"https://www.u-claw.org/guide.html\"},{\"type\":\"hardBreak\"},{\"type\":\"text\",\"marks\":[{\"type\":\"link\",\"attrs\":{\"href\":\"https://github.com/dongsheng123132/u-claw\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer nofollow\",\"class\":null}},{\"type\":\"underline\"}],\"text\":\"https://github.com/dongsheng123132/u-claw\"}]}]}","title":"把 OpenClaw 装进U盘，快速部署即插即用","tags":[],"updateTime":1777420258774,"createTime":1777420256641,"draft":false,"intro":"使用 dongsheng123132 的项目，一键制作龙虾U盘吧。","html":"<h1 level=\"1\" id=\"把-OpenClaw-装进U盘快速部署即插即用\"><strong>把 OpenClaw 装进U盘，快速部署即插即用</strong></h1><p>使用 dongsheng123132 的项目，一键制作龙虾U盘吧。</p><p>通过&nbsp;<a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://github.com/dongsheng123132/u-claw\"><u>GitHub</u></a>&nbsp;的 U-Claw 达成把 OpenClaw 装进u盘里，做成 U 盘可插任意电脑，双击即用，便携虾！</p><p><strong>两种 U 盘模式</strong></p><p><strong>便携版 U 盘Linux 启动盘原理</strong>在已有系统（Mac/Win/Linux）上运行 U 盘里的脚本从 U 盘启动整个 Linux 系统 + OpenClaw<strong>U 盘要求</strong>4GB+<strong>64GB+ USB 3.0</strong>（USB 2.0 太慢不推荐）<strong>依赖</strong>电脑已有操作系统不依赖任何已装系统<strong>适合</strong>临时用、公共电脑、演示专用 AI 工作站、无系统裸机</p><p>下面为该项目的部署教程：</p><h3 level=\"3\" id=\"快速开始制作便携版-U-盘\">快速开始：制作便携版 U 盘</h3><div class=\"llt-code readonly\"><div class=\"language\">bash</div><div class=\"wrapper\"><pre><code><span class=\"hljs-comment\" class=\"hljs-comment\"># 1. 克隆代码</span>\ngit <span class=\"hljs-built_in\" class=\"hljs-built_in\">clone</span> https://github.com/dongsheng123132/u-claw.git\n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># 2. 补齐大依赖（Node.js + OpenClaw，国内镜像，约 1 分钟）</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">cd</span> u-claw/portable &amp;&amp; bash setup.sh\n\n<span class=\"hljs-comment\" class=\"hljs-comment\"># 3. 拷贝到 U 盘</span>\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">cp</span> -R portable/ /Volumes/你的U盘/U-Claw/   <span class=\"hljs-comment\" class=\"hljs-comment\"># Mac</span>\n<span class=\"hljs-comment\" class=\"hljs-comment\"># 或 Windows 资源管理器直接拖过去</span></code></pre></div></div><p><strong>完成！</strong>&nbsp;插上 U 盘，双击启动脚本就能用。</p><h3 level=\"3\" id=\"制作-Linux-启动盘\">制作 Linux 启动盘</h3><p>把整个 Linux 系统 + OpenClaw 刻在 U 盘，开机从 USB 启动直接进入 AI 助手桌面。</p><p><strong>准备：</strong></p><ul><li><p><strong>64GB+ USB 3.0 U 盘</strong>（推荐三星 BAR Plus、闪迪 CZ880 等高速盘）</p></li><li><p>Linux Mint ISO（<a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://mirrors.tuna.tsinghua.edu.cn/linuxmint-cd/stable/\"><u>清华镜像</u></a>&nbsp;/&nbsp;<a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://mirrors.ustc.edu.cn/linuxmint-cd/stable/\"><u>中科大镜像</u></a>）</p></li><li><p>Rufus v4.0+（<a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://rufus.ie/zh/\"><u>rufus.ie</u></a>）</p></li></ul><p><strong>步骤：</strong></p><ol><li><p>Rufus 刻录 ISO → 开启&nbsp;<strong>Persistent Storage</strong>（8-16GB）</p></li><li><p>USB 启动 → 进入 Linux Mint 桌面 → 连网</p></li><li><p>运行安装脚本：</p><div class=\"llt-code readonly\"><div class=\"language\">arduino</div><div class=\"wrapper\"><pre><code>curl -O https:<span class=\"hljs-comment\" class=\"hljs-comment\">//raw.githubusercontent.com/dongsheng123132/u-claw/main/portable/setup-linux-usb.sh</span>\nbash setup-linux-usb.sh</code></pre></div></div></li></ol><p>详细图文教程见&nbsp;<a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://u-claw.org/guide.html\"><u>guide.html → Linux 启动盘模式</u></a>。</p><h3 level=\"3\" id=\"U-盘功能一览\">U 盘功能一览</h3><p><strong>功能MacWindowsLinux免安装运行</strong><code>Mac-Start.commandWindows-Start.batbash Linux-Start.sh</code><strong>功能菜单</strong><code>Mac-Menu.commandWindows-Menu.batbash Linux-Menu.sh</code><strong>安装到电脑</strong><code>Mac-Install.commandWindows-Install.batbash Linux-Install.sh</code><strong>首次配置</strong><code>Config.htmlConfig.htmlConfig.html</code></p><h3 level=\"3\" id=\"U-盘文件结构\">U 盘文件结构</h3><div class=\"llt-code readonly\"><div class=\"language\">arduino</div><div class=\"wrapper\"><pre><code>U-Claw/                          ← 整个拷到 U 盘\n├── Mac-Start.command             Mac 免安装运行\n├── Mac-Menu.command              Mac 功能菜单\n├── Mac-Install.command           安装到 Mac\n├── Windows-Start.bat             Windows 免安装运行\n├── Windows-Menu.bat              Windows 功能菜单\n├── Windows-Install.bat           安装到 Windows\n├── Linux-Start.sh                Linux 免安装运行\n├── Linux-Menu.sh                 Linux 功能菜单\n├── Linux-Install.sh              安装到 Linux\n├── setup-linux-usb.sh            Linux 启动盘内安装 OpenClaw\n├── Config.html                   首次配置页面\n├── setup.sh                      补齐依赖（开发者用）\n├── app/                          ← 大依赖（setup.sh 下载，不进 git）\n│   ├── core/                        OpenClaw + QQ 插件\n│   └── runtime/\n│       ├── node-mac-arm64/          Mac Apple Silicon\n│       ├── node-win-x64/           Windows <span class=\"hljs-number\" class=\"hljs-number\">64</span>-bit\n│       └── node-linux-x64/         Linux x86_64\n└── data/                         ← 用户数据（不进 git）\n    ├── .openclaw/                   配置文件\n    ├── memory/                      AI 记忆\n    └── backups/                     备份</code></pre></div></div><h3 level=\"3\" id=\"桌面安装版Electron-App\">桌面安装版（Electron App）</h3><p>除了 U 盘便携版，还有桌面 App 版本：</p><div class=\"llt-code readonly\"><div class=\"language\">bash</div><div class=\"wrapper\"><pre><code><span class=\"hljs-built_in\" class=\"hljs-built_in\">cd</span> u-claw-app\nbash setup.sh            <span class=\"hljs-comment\" class=\"hljs-comment\"># 一键安装开发环境（国内镜像）</span>\nnpm run dev              <span class=\"hljs-comment\" class=\"hljs-comment\"># 开发模式运行</span>\nnpm run build:mac-arm64  <span class=\"hljs-comment\" class=\"hljs-comment\"># 打包 → release/*.dmg</span>\nnpm run build:win        <span class=\"hljs-comment\" class=\"hljs-comment\"># 打包 → release/*.exe</span></code></pre></div></div><h3 level=\"3\" id=\"支持的-AI-模型\">支持的 AI 模型</h3><p><strong>国产模型（无需翻墙）：</strong></p><p><strong>模型推荐场景</strong>DeepSeek编程首选，极便宜Kimi K2.5长文档，256K 上下文通义千问 Qwen免费额度大智谱 GLM学术场景MiniMax语音多模态豆包 Doubao火山引擎</p><p><strong>国际模型：</strong>&nbsp;Claude · GPT · Gemini（需翻墙或中转）</p><h3 level=\"3\" id=\"支持的聊天平台\">支持的聊天平台</h3><p><strong>平台状态说明</strong>QQ✅ 已预装输入 AppID + Secret 即可飞书✅ 内置企业首选Telegram✅ 内置海外推荐WhatsApp✅ 内置Baileys 协议Discord✅ 内置—微信✅ 社区插件iPad 协议</p><h3 level=\"3\" id=\"国内镜像\">国内镜像</h3><p>所有脚本默认走国内镜像，无需翻墙：</p><p><strong>资源镜像</strong>npm 包<code>registry.npmmirror.com</code>Node.js<code>npmmirror.com/mirrors/node</code>Electron<code>npmmirror.com/mirrors/electron</code></p><h3 level=\"3\" id=\"开发--贡献\">开发 &amp; 贡献</h3><div class=\"llt-code readonly\"><div class=\"language\">bash</div><div class=\"wrapper\"><pre><code>git <span class=\"hljs-built_in\" class=\"hljs-built_in\">clone</span> https://github.com/dongsheng123132/u-claw.git\n<span class=\"hljs-built_in\" class=\"hljs-built_in\">cd</span> u-claw/portable &amp;&amp; bash setup.sh\nbash Mac-Start.<span class=\"hljs-built_in\" class=\"hljs-built_in\">command</span>   <span class=\"hljs-comment\" class=\"hljs-comment\"># Mac 测试</span>\nbash Linux-Start.sh      <span class=\"hljs-comment\" class=\"hljs-comment\"># Linux 测试</span></code></pre></div></div><p><strong>平台支持：</strong></p><p><strong>平台状态</strong>Mac Apple Silicon (M1-M4)✅Linux x86_64✅Linux ARM64✅Windows x64🚧 开发中Mac Intel❌ 暂不支持</p><h2 level=\"2\" id=\"相关链接\">相关链接</h2><p><a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://www.u-claw.org/guide.html\"><u>https://www.u-claw.org/guide.html</u></a><br><a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://github.com/dongsheng123132/u-claw\"><u>https://github.com/dongsheng123132/u-claw</u></a></p><script type=\"module\">const injectHtml = (root, html) => {\n  const iframe = document.createElement(\"iframe\");\n  const htmlContent = `<html><head></head><body>${html}</body></html>`;\n  iframe.style.width = \"100%\";\n  iframe.style.height = \"100%\";\n  iframe.onload = () => {\n    const doc = iframe.contentDocument || iframe.contentWindow?.document;\n    if (!doc) {\n      return;\n    }\n    doc.open();\n    doc.write(htmlContent);\n    doc.close();\n  };\n  root.replaceChildren(iframe);\n}\n  document.querySelectorAll('.playground')?.forEach(el=>{\n    const html = el.getAttribute('data-html');\n    if (html) {\n      injectHtml(el,html);\n    }\n    const indicator = document.createElement(\"div\");\n    indicator.className = \"indicator\";\n    const showCode = document.createElement(\"div\");\n    showCode.className = \"show-code\";\n    showCode.innerText = \"code\";\n    showCode.onclick = () => {\n      el.parentElement.classList.remove(\"preview-only\");\n    };\n    const showPreview = document.createElement(\"div\");\n    showPreview.className = \"show-preview\";\n    showPreview.innerText = \"preview\";\n    showPreview.onclick = () => {\n      el.parentElement.classList.add(\"preview-only\");\n    };\n    indicator.appendChild(showCode);\n    indicator.appendChild(showPreview);\n    el.parentElement.appendChild(indicator);\n    if (window.screen.width < 768) {\n      showPreview.click();\n    }\n  });</script>","id":"把-OpenClaw-装进U盘快速部署即插即用","path":"/posts/把-OpenClaw-装进U盘快速部署即插即用.json"}